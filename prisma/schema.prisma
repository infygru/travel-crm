generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(AGENT)
  isActive      Boolean   @default(true)
  phone         String?
  department    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  assignedContacts Contact[]    @relation("ContactOwner")
  assignedDeals    Deal[]       @relation("DealOwner")
  assignedBookings Booking[]    @relation("BookingAgent")
  tasks            Task[]       @relation("TaskAssignee")
  createdTasks     Task[]       @relation("TaskCreator")
  activities       Activity[]
  notes            Note[]

  createdTemplates    MessageTemplate[]     @relation("TemplateCreator")
  createdSegments     ContactSegment[]      @relation("SegmentCreator")
  createdCampaigns    Campaign[]            @relation("CampaignCreator")
  createdSequences    EmailSequence[]       @relation("SequenceCreator")
  createdAutomations  AutomationRule[]      @relation("AutomationCreator")
  createdItineraries  Itinerary[]           @relation("ItineraryCreator")
  createdQuotes       Quote[]               @relation("QuoteCreator")
  mergeLogs           LeadMergeLog[]        @relation("MergeOperator")
  ownedForms          WebLeadForm[]         @relation("FormOwner")
  createdTickets      SupportTicket[]       @relation("TicketCreator")
  assignedTickets     SupportTicket[]       @relation("TicketAssignee")
  ticketReplies       TicketReply[]         @relation("ReplyAuthor")
  statusChanges       TicketStatusHistory[] @relation("StatusChanger")
  escalatedByMe       TicketEscalation[]    @relation("EscalatedBy")
  escalatedToMe       TicketEscalation[]    @relation("EscalatedTo")
  canvaToken          String?
  canvaDesigns        CanvaDesign[]         @relation("CanvaDesignCreator")
  importLogs          ImportLog[]           @relation("ImportLogCreator")
  conversations       Conversation[]        @relation("ConversationAssignee")
  sentMessages        ConversationMessage[] @relation("MessageSender")

  @@map("users")
}

enum UserRole {
  ADMIN
  MANAGER
  AGENT
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// CRM CORE
// ─────────────────────────────────────────────

model Company {
  id          String   @id @default(cuid())
  name        String
  website     String?
  industry    String?
  size        String?
  country     String?
  city        String?
  address     String?
  phone       String?
  email       String?
  description String?
  logoUrl     String?
  revenue     Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contacts   Contact[]
  deals      Deal[]
  notes      Note[]
  activities Activity[]

  @@map("companies")
}

model Contact {
  id               String           @id @default(cuid())
  firstName        String
  lastName         String
  email            String?          @unique
  phone            String?
  mobile           String?
  jobTitle         String?
  department       String?
  country          String?
  city             String?
  address          String?
  avatarUrl        String?
  leadSource       LeadSource?
  leadStatus       LeadStatus       @default(NEW)
  leadScore        Int              @default(0)
  tags             String[]
  preferredContact PreferredContact @default(EMAIL)
  dateOfBirth      DateTime?
  passportNumber   String?
  passportExpiry   DateTime?
  nationality      String?
  travelPreferences Json?
  loyaltyPoints    Int              @default(0)
  totalSpent       Float            @default(0)
  notes            String?
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  ownerId   String?
  owner     User?    @relation("ContactOwner", fields: [ownerId], references: [id])

  deals      Deal[]
  bookings   Booking[]
  passengers Passenger[]
  tasks      Task[]
  noteRels   Note[]
  activities Activity[]
  emails     EmailLog[]

  campaignSends       CampaignSend[]
  sequenceEnrollments SequenceEnrollment[]
  unsubscribes        Unsubscribe[]
  itineraries         Itinerary[]
  scoreHistory        LeadScoreHistory[]
  sourceTracking      LeadSourceTracking?
  mergeLogsAsPrimary  LeadMergeLog[]       @relation("PrimaryContact")
  webSubmissions      WebLeadSubmission[]
  tickets             SupportTicket[]
  canvaDesigns        CanvaDesign[]
  quotes              Quote[]
  conversations       Conversation[]

  @@map("contacts")
}

enum LeadSource {
  WEBSITE
  REFERRAL
  SOCIAL_MEDIA
  COLD_CALL
  EMAIL_CAMPAIGN
  TRADE_SHOW
  PARTNER
  ADVERTISEMENT
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  CONVERTED
  LOST
  UNQUALIFIED
}

enum PreferredContact {
  EMAIL
  PHONE
  WHATSAPP
  SMS
}

// ─────────────────────────────────────────────
// DEALS / PIPELINE
// ─────────────────────────────────────────────

model Pipeline {
  id          String   @id @default(cuid())
  name        String
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stages PipelineStage[]
  deals  Deal[]

  @@map("pipelines")
}

model PipelineStage {
  id          String   @id @default(cuid())
  name        String
  order       Int
  color       String   @default("#6366f1")
  probability Float    @default(0)
  pipelineId  String
  pipeline    Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals       Deal[]

  @@map("pipeline_stages")
}

model Deal {
  id            String        @id @default(cuid())
  title         String
  value         Float         @default(0)
  currency      String        @default("INR")
  probability   Float         @default(0)
  expectedClose DateTime?
  actualClose   DateTime?
  status        DealStatus    @default(OPEN)
  priority      Priority      @default(MEDIUM)
  description   String?
  lostReason    String?
  tags          String[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  pipelineId String?
  pipeline   Pipeline?      @relation(fields: [pipelineId], references: [id])
  stageId    String?
  stage      PipelineStage? @relation(fields: [stageId], references: [id])
  contactId  String?
  contact    Contact?       @relation(fields: [contactId], references: [id])
  companyId  String?
  company    Company?       @relation(fields: [companyId], references: [id])
  ownerId    String?
  owner      User?          @relation("DealOwner", fields: [ownerId], references: [id])
  packageId  String?
  package    TravelPackage? @relation(fields: [packageId], references: [id])

  bookings    Booking[]
  tasks       Task[]
  notes       Note[]
  activities  Activity[]
  itineraries Itinerary[]
  tickets     SupportTicket[]
  quotes      Quote[]

  @@map("deals")
}

enum DealStatus {
  OPEN
  WON
  LOST
  ON_HOLD
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─────────────────────────────────────────────
// TRAVEL PACKAGES
// ─────────────────────────────────────────────

model TravelPackage {
  id           String          @id @default(cuid())
  name         String
  code         String?         @unique
  description  String?
  destinations String[]
  duration     Int
  basePrice    Float
  currency     String          @default("INR")
  maxPax       Int?
  minPax       Int             @default(1)
  inclusions   String[]
  exclusions   String[]
  highlights   String[]
  category     PackageCategory
  difficulty   String?
  isActive     Boolean         @default(true)
  imageUrl     String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  deals     Deal[]
  bookings  Booking[]
  itinerary ItineraryDay[]

  @@map("travel_packages")
}

enum PackageCategory {
  ADVENTURE
  LUXURY
  FAMILY
  HONEYMOON
  BUSINESS
  GROUP_TOUR
  CRUISE
  SAFARI
  BEACH
  CULTURAL
  PILGRIMAGE
  SPORTS
  OTHER
}

model ItineraryDay {
  id            String        @id @default(cuid())
  packageId     String
  package       TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  day           Int
  title         String
  description   String?
  location      String?
  meals         String[]
  activities    String[]
  accommodation String?
  transport     String?

  @@map("itinerary_days")
}

// ─────────────────────────────────────────────
// BOOKINGS
// ─────────────────────────────────────────────

model Booking {
  id              String        @id @default(cuid())
  bookingRef      String        @unique @default(cuid())
  status          BookingStatus @default(PENDING)
  startDate       DateTime
  endDate         DateTime
  adults          Int           @default(1)
  children        Int           @default(0)
  infants         Int           @default(0)
  totalAmount     Float
  costPrice       Float         @default(0)
  paidAmount      Float         @default(0)
  currency        String        @default("INR")
  paymentStatus   PaymentStatus @default(UNPAID)
  specialRequests String?
  internalNotes   String?
  destinations    String[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  contactId String?
  contact   Contact?       @relation(fields: [contactId], references: [id])
  packageId String?
  package   TravelPackage? @relation(fields: [packageId], references: [id])
  dealId    String?
  deal      Deal?          @relation(fields: [dealId], references: [id])
  agentId   String?
  agent     User?          @relation("BookingAgent", fields: [agentId], references: [id])

  shareToken  String?  @unique
  sharedAt    DateTime?

  passengers       Passenger[]
  payments         Payment[]
  documents        Document[]
  tasks            Task[]
  notes            Note[]
  activities       Activity[]
  tickets          SupportTicket[]
  supplierPayments SupplierPayment[]

  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
  OVERDUE
}

model Passenger {
  id             String        @id @default(cuid())
  bookingId      String
  booking        Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  contactId      String?
  contact        Contact?      @relation(fields: [contactId], references: [id])
  firstName      String
  lastName       String
  email          String?
  phone          String?
  dateOfBirth    DateTime?
  gender         String?
  nationality    String?
  passportNumber String?
  passportExpiry DateTime?
  issuingCountry String?
  type           PassengerType @default(ADULT)
  seatPreference String?
  mealPreference String?
  specialNeeds   String?
  individualCost Float         @default(0)

  @@map("passengers")
}

enum PassengerType {
  ADULT
  CHILD
  INFANT
}

model Payment {
  id        String        @id @default(cuid())
  bookingId String
  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amount    Float
  currency  String        @default("INR")
  method    PaymentMethod
  status    PaymentStatus @default(UNPAID)
  reference String?
  paidAt    DateTime?
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("payments")
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CREDIT_CARD
  DEBIT_CARD
  UPI
  PAYPAL
  STRIPE
  CHECK
  OTHER
}

model Document {
  id        String       @id @default(cuid())
  bookingId String
  booking   Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  name      String
  type      DocumentType
  url       String
  size      Int?
  mimeType  String?
  createdAt DateTime     @default(now())

  @@map("documents")
}

enum DocumentType {
  PASSPORT
  VISA
  TICKET
  VOUCHER
  INVOICE
  INSURANCE
  ITINERARY
  OTHER
}

// ─────────────────────────────────────────────
// TASKS & ACTIVITIES
// ─────────────────────────────────────────────

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  type        TaskType   @default(FOLLOW_UP)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  assigneeId String?
  assignee   User?    @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creatorId  String?
  creator    User?    @relation("TaskCreator", fields: [creatorId], references: [id])
  contactId  String?
  contact    Contact? @relation(fields: [contactId], references: [id])
  dealId     String?
  deal       Deal?    @relation(fields: [dealId], references: [id])
  bookingId  String?
  booking    Booking? @relation(fields: [bookingId], references: [id])

  @@map("tasks")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskType {
  CALL
  EMAIL
  MEETING
  FOLLOW_UP
  DOCUMENT
  QUOTE
  OTHER
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  title       String
  description String?
  metadata    Json?
  createdAt   DateTime     @default(now())

  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id])
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id])

  @@map("activities")
}

enum ActivityType {
  NOTE_ADDED
  CALL_LOGGED
  EMAIL_SENT
  MEETING_SCHEDULED
  DEAL_CREATED
  DEAL_STAGE_CHANGED
  DEAL_WON
  DEAL_LOST
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  PAYMENT_RECEIVED
  TASK_CREATED
  TASK_COMPLETED
  CONTACT_CREATED
  STATUS_CHANGED
  TICKET_CREATED
  TICKET_STATUS_CHANGED
  TICKET_REPLIED
  TICKET_ESCALATED
  TICKET_RESOLVED
  CAMPAIGN_SENT
  SEQUENCE_ENROLLED
  ITINERARY_CREATED
  ITINERARY_SHARED
  ITINERARY_APPROVED
  LEAD_SCORE_CHANGED
  LEAD_MERGED
  FORM_SUBMITTED
}

model Note {
  id        String   @id @default(cuid())
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id])
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id])

  @@map("notes")
}

model EmailLog {
  id        String      @id @default(cuid())
  subject   String
  body      String      @db.Text
  status    EmailStatus @default(SENT)
  from      String
  to        String
  cc        String?
  bcc       String?
  sentAt    DateTime    @default(now())

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  @@map("email_logs")
}

enum EmailStatus {
  SENT
  FAILED
  BOUNCED
  OPENED
  CLICKED
}

// ─────────────────────────────────────────────
// COMMUNICATION & MARKETING
// ─────────────────────────────────────────────

model MessageTemplate {
  id          String         @id @default(cuid())
  name        String
  channel     MessageChannel
  subject     String?
  body        String         @db.Text
  variables   String[]
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  createdById String?
  createdBy   User?          @relation("TemplateCreator", fields: [createdById], references: [id])
  campaigns   Campaign[]
  sequences   SequenceStep[]

  @@map("message_templates")
}

enum MessageChannel {
  EMAIL
  SMS
  WHATSAPP
}

model ContactSegment {
  id          String   @id @default(cuid())
  name        String
  description String?
  filters     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation("SegmentCreator", fields: [createdById], references: [id])
  campaigns   Campaign[]

  @@map("contact_segments")
}

model Campaign {
  id           String         @id @default(cuid())
  name         String
  description  String?
  channel      MessageChannel
  type         CampaignType
  status       CampaignStatus @default(DRAFT)
  scheduledAt  DateTime?
  sentAt       DateTime?
  subject      String?
  body         String?        @db.Text
  fromName     String?
  fromEmail    String?
  replyTo      String?
  totalSent    Int            @default(0)
  delivered    Int            @default(0)
  opened       Int            @default(0)
  clicked      Int            @default(0)
  unsubscribed Int            @default(0)
  bounced      Int            @default(0)
  conversions  Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  templateId   String?
  template     MessageTemplate?  @relation(fields: [templateId], references: [id])
  segmentId    String?
  segment      ContactSegment?   @relation(fields: [segmentId], references: [id])
  createdById  String?
  createdBy    User?             @relation("CampaignCreator", fields: [createdById], references: [id])
  sequenceId   String?
  sequence     EmailSequence?    @relation(fields: [sequenceId], references: [id])
  sends        CampaignSend[]

  @@map("campaigns")
}

enum CampaignType {
  BROADCAST
  DRIP
  TRANSACTIONAL
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  CANCELLED
}

model CampaignSend {
  id             String     @id @default(cuid())
  status         SendStatus @default(PENDING)
  sentAt         DateTime?
  deliveredAt    DateTime?
  openedAt       DateTime?
  clickedAt      DateTime?
  unsubscribedAt DateTime?
  bouncedAt      DateTime?
  errorMessage   String?
  externalId     String?
  metadata       Json?
  campaignId     String
  campaign       Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId      String
  contact        Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
  @@map("campaign_sends")
}

enum SendStatus {
  PENDING
  SENT
  DELIVERED
  OPENED
  CLICKED
  UNSUBSCRIBED
  BOUNCED
  FAILED
}

model EmailSequence {
  id          String          @id @default(cuid())
  name        String
  description String?
  isActive    Boolean         @default(true)
  triggerType SequenceTrigger
  triggerData Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdById String?
  createdBy   User?           @relation("SequenceCreator", fields: [createdById], references: [id])
  steps       SequenceStep[]
  enrollments SequenceEnrollment[]
  campaigns   Campaign[]
  automations AutomationRule[] @relation("AutomationSequence")

  @@map("email_sequences")
}

enum SequenceTrigger {
  MANUAL
  LEAD_CREATED
  LEAD_STATUS_CHANGED
  DEAL_CREATED
  DEAL_STAGE_CHANGED
  BOOKING_CONFIRMED
  TAG_ADDED
}

model SequenceStep {
  id         String         @id @default(cuid())
  sequenceId String
  sequence   EmailSequence  @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  order      Int
  delayDays  Int            @default(0)
  delayHours Int            @default(0)
  channel    MessageChannel
  subject    String?
  body       String?        @db.Text
  templateId String?
  template   MessageTemplate? @relation(fields: [templateId], references: [id])

  @@map("sequence_steps")
}

model SequenceEnrollment {
  id          String           @id @default(cuid())
  sequenceId  String
  sequence    EmailSequence    @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  currentStep Int              @default(0)
  status      EnrollmentStatus @default(ACTIVE)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  nextSendAt  DateTime?

  @@unique([sequenceId, contactId])
  @@map("sequence_enrollments")
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  PAUSED
  UNSUBSCRIBED
  CANCELLED
}

model AutomationRule {
  id          String            @id @default(cuid())
  name        String
  description String?
  isActive    Boolean           @default(true)
  triggerType AutomationTrigger
  triggerData Json?
  conditions  Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  createdById String?
  createdBy   User?             @relation("AutomationCreator", fields: [createdById], references: [id])
  actions     AutomationAction[]
  sequenceId  String?
  sequence    EmailSequence?    @relation("AutomationSequence", fields: [sequenceId], references: [id])

  @@map("automation_rules")
}

enum AutomationTrigger {
  CONTACT_CREATED
  LEAD_STATUS_CHANGED
  DEAL_CREATED
  DEAL_STAGE_CHANGED
  DEAL_WON
  DEAL_LOST
  BOOKING_CREATED
  BOOKING_CONFIRMED
  TAG_ADDED
  FORM_SUBMITTED
}

model AutomationAction {
  id     String               @id @default(cuid())
  ruleId String
  rule   AutomationRule       @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  order  Int
  type   AutomationActionType
  config Json

  @@map("automation_actions")
}

enum AutomationActionType {
  SEND_EMAIL
  SEND_SMS
  SEND_WHATSAPP
  ASSIGN_TASK
  CHANGE_LEAD_STATUS
  CHANGE_DEAL_STAGE
  ENROLL_SEQUENCE
  ASSIGN_OWNER
  ADD_TAG
  SEND_NOTIFICATION
}

model Unsubscribe {
  id        String         @id @default(cuid())
  channel   MessageChannel
  contactId String
  contact   Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  reason    String?
  createdAt DateTime       @default(now())

  @@unique([channel, contactId])
  @@map("unsubscribes")
}

// ─────────────────────────────────────────────
// ITINERARY BUILDER
// ─────────────────────────────────────────────

model Itinerary {
  id          String          @id @default(cuid())
  title       String
  description String?
  status      ItineraryStatus @default(DRAFT)
  version     Int             @default(1)
  shareToken  String?         @unique @default(cuid())
  sharedAt    DateTime?
  approvedAt  DateTime?
  totalCost   Float           @default(0)
  currency    String          @default("INR")
  startDate   DateTime?
  endDate     DateTime?
  notes       String?         @db.Text
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  contactId   String?
  contact     Contact?        @relation(fields: [contactId], references: [id])
  dealId      String?
  deal        Deal?           @relation(fields: [dealId], references: [id])
  createdById String?
  createdBy   User?           @relation("ItineraryCreator", fields: [createdById], references: [id])
  days        ItineraryDayPlan[]
  canvaDesigns CanvaDesign[]

  @@map("itineraries")
}

enum ItineraryStatus {
  DRAFT
  SHARED
  APPROVED
  BOOKED
  ARCHIVED
}

model ItineraryDayPlan {
  id          String    @id @default(cuid())
  itineraryId String
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  dayNumber   Int
  date        DateTime?
  title       String?
  description String?
  location    String?
  items       ItineraryItem[]

  @@unique([itineraryId, dayNumber])
  @@map("itinerary_day_plans")
}

model ItineraryItem {
  id              String            @id @default(cuid())
  dayPlanId       String
  dayPlan         ItineraryDayPlan  @relation(fields: [dayPlanId], references: [id], onDelete: Cascade)
  order           Int
  type            ItineraryItemType
  title           String
  description     String?
  location        String?
  startTime       String?
  endTime         String?
  duration        Int?
  supplier        String?
  confirmationRef String?
  unitCost        Float             @default(0)
  quantity        Int               @default(1)
  totalCost       Float             @default(0)
  currency        String            @default("INR")
  isIncluded      Boolean           @default(true)
  notes           String?
  metadata        Json?

  @@map("itinerary_items")
}

enum ItineraryItemType {
  FLIGHT
  HOTEL
  ACTIVITY
  TRANSFER
  MEAL
  FREE_TIME
  OTHER
}

// ─────────────────────────────────────────────
// LEAD MANAGEMENT
// ─────────────────────────────────────────────

model LeadScoringRule {
  id          String          @id @default(cuid())
  name        String
  description String?
  isActive    Boolean         @default(true)
  ruleType    ScoringRuleType
  conditions  Json
  scorePoints Int
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("lead_scoring_rules")
}

enum ScoringRuleType {
  PROFILE_COMPLETENESS
  ACTIVITY_EVENT
  ENGAGEMENT
  DEAL_VALUE
  RECENCY
  TAG_MATCH
  MANUAL
}

model LeadScoreHistory {
  id          String   @id @default(cuid())
  contactId   String
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  delta       Int
  scoreBefore Int
  scoreAfter  Int
  reason      String
  ruleId      String?
  createdAt   DateTime @default(now())

  @@map("lead_score_history")
}

model LeadSourceTracking {
  id          String   @id @default(cuid())
  contactId   String   @unique
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  referrerUrl String?
  landingPage String?
  ipAddress   String?
  userAgent   String?
  capturedAt  DateTime @default(now())

  @@map("lead_source_tracking")
}

model LeadAssignmentRule {
  id         String         @id @default(cuid())
  name       String
  isActive   Boolean        @default(true)
  order      Int
  type       AssignmentType
  conditions Json?
  config     Json
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@map("lead_assignment_rules")
}

enum AssignmentType {
  ROUND_ROBIN
  SPECIFIC_USER
  LEAST_LOADED
  MANAGER_ONLY
}

model RoundRobinState {
  id         String   @id @default(cuid())
  ruleId     String   @unique
  userIds    String[]
  currentIdx Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@map("round_robin_state")
}

model LeadMergeLog {
  id               String   @id @default(cuid())
  primaryContactId String
  primaryContact   Contact  @relation("PrimaryContact", fields: [primaryContactId], references: [id])
  mergedContactId  String
  mergedData       Json
  mergedById       String?
  mergedBy         User?    @relation("MergeOperator", fields: [mergedById], references: [id])
  createdAt        DateTime @default(now())

  @@map("lead_merge_logs")
}

model WebLeadForm {
  id              String      @id @default(cuid())
  name            String
  title           String?
  description     String?
  fields          Json
  defaultTags     String[]
  defaultSource   LeadSource?
  defaultOwnerId  String?
  defaultOwner    User?       @relation("FormOwner", fields: [defaultOwnerId], references: [id])
  embedToken      String      @unique @default(cuid())
  redirectUrl     String?
  isActive        Boolean     @default(true)
  submissionCount Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  submissions     WebLeadSubmission[]

  @@map("web_lead_forms")
}

model WebLeadSubmission {
  id          String           @id @default(cuid())
  formId      String
  form        WebLeadForm      @relation(fields: [formId], references: [id])
  data        Json
  ipAddress   String?
  userAgent   String?
  status      SubmissionStatus @default(PENDING)
  contactId   String?
  contact     Contact?         @relation(fields: [contactId], references: [id])
  processedAt DateTime?
  createdAt   DateTime         @default(now())

  @@map("web_lead_submissions")
}

enum SubmissionStatus {
  PENDING
  CONVERTED
  DUPLICATE
  SPAM
}

// ─────────────────────────────────────────────
// SUPPORT TICKETS
// ─────────────────────────────────────────────

model SupportTicket {
  id              String         @id @default(cuid())
  ticketNumber    String         @unique
  subject         String
  description     String         @db.Text
  category        TicketCategory
  priority        Priority
  status          TicketStatus   @default(OPEN)
  channel         TicketChannel  @default(MANUAL)
  slaBreached     Boolean        @default(false)
  slaDeadline     DateTime?
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?
  csatScore       Int?
  csatComment     String?
  csatSubmittedAt DateTime?
  internalNotes   String?        @db.Text
  tags            String[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdById     String?
  createdBy       User?          @relation("TicketCreator", fields: [createdById], references: [id])
  assigneeId      String?
  assignee        User?          @relation("TicketAssignee", fields: [assigneeId], references: [id])
  contactId       String?
  contact         Contact?       @relation(fields: [contactId], references: [id])
  bookingId       String?
  booking         Booking?       @relation(fields: [bookingId], references: [id])
  dealId          String?
  deal            Deal?          @relation(fields: [dealId], references: [id])
  replies         TicketReply[]
  escalations     TicketEscalation[]
  statusHistory   TicketStatusHistory[]

  @@map("support_tickets")
}

enum TicketCategory {
  BOOKING_ISSUE
  REFUND_REQUEST
  COMPLAINT
  GENERAL_INQUIRY
  DOCUMENT_REQUEST
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PENDING_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketChannel {
  EMAIL
  PHONE
  WHATSAPP
  WEB_FORM
  MANUAL
}

model TicketReply {
  id          String        @id @default(cuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  body        String        @db.Text
  isInternal  Boolean       @default(false)
  authorId    String?
  author      User?         @relation("ReplyAuthor", fields: [authorId], references: [id])
  fromEmail   String?
  attachments Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("ticket_replies")
}

model TicketStatusHistory {
  id          String        @id @default(cuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fromStatus  TicketStatus?
  toStatus    TicketStatus
  changedById String?
  changedBy   User?         @relation("StatusChanger", fields: [changedById], references: [id])
  reason      String?
  createdAt   DateTime      @default(now())

  @@map("ticket_status_history")
}

model TicketEscalation {
  id            String        @id @default(cuid())
  ticketId      String
  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  reason        String
  escalatedById String?
  escalatedBy   User?         @relation("EscalatedBy", fields: [escalatedById], references: [id])
  escalatedToId String?
  escalatedTo   User?         @relation("EscalatedTo", fields: [escalatedToId], references: [id])
  resolvedAt    DateTime?
  createdAt     DateTime      @default(now())

  @@map("ticket_escalations")
}

model SlaConfig {
  id                   String   @id @default(cuid())
  priority             Priority @unique
  firstResponseHours   Int
  resolutionHours      Int
  escalationAfterHours Int?
  updatedAt            DateTime @updatedAt

  @@map("sla_configs")
}

// ─────────────────────────────────────────────
// CANVA INTEGRATION
// ─────────────────────────────────────────────

model CanvaDesign {
  id           String   @id @default(cuid())
  canvaId      String   @unique
  title        String
  designType   String
  thumbnailUrl String?
  editUrl      String?
  exportUrl    String?
  status       String   @default("DRAFT")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdById String?
  createdBy   User?      @relation("CanvaDesignCreator", fields: [createdById], references: [id])
  contactId   String?
  contact     Contact?   @relation(fields: [contactId], references: [id])
  itineraryId String?
  itinerary   Itinerary? @relation(fields: [itineraryId], references: [id])

  @@map("canva_designs")
}

// ─────────────────────────────────────────────
// SUPPLIERS
// ─────────────────────────────────────────────

model Supplier {
  id           String           @id @default(cuid())
  name         String
  category     SupplierCategory
  email        String?
  phone        String?
  website      String?
  country      String?
  city         String?
  address      String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  bankDetails  Json?
  paymentTerms String?
  rating       Int?
  notes        String?
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  payments SupplierPayment[]

  @@map("suppliers")
}

enum SupplierCategory {
  HOTEL
  AIRLINE
  TRANSFER
  ACTIVITY
  RESTAURANT
  VISA_AGENT
  INSURANCE
  CRUISE
  OTHER
}

model SupplierPayment {
  id         String               @id @default(cuid())
  supplierId String
  supplier   Supplier             @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  bookingId  String?
  booking    Booking?             @relation(fields: [bookingId], references: [id])
  amount     Float
  currency   String               @default("INR")
  dueDate    DateTime?
  paidDate   DateTime?
  status     SupplierPaymentStatus @default(PENDING)
  reference  String?
  notes      String?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@map("supplier_payments")
}

enum SupplierPaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

// ─────────────────────────────────────────────
// QUOTES / PROPOSALS
// ─────────────────────────────────────────────

model Quote {
  id            String      @id @default(cuid())
  quoteNumber   String      @unique
  title         String
  status        QuoteStatus @default(DRAFT)
  validUntil    DateTime?
  currency      String      @default("INR")
  subtotal      Float       @default(0)
  discount      Float       @default(0)
  taxes         Float       @default(0)
  totalAmount   Float       @default(0)
  notes         String?     @db.Text
  terms         String?     @db.Text
  shareToken    String?     @unique @default(cuid())
  sharedAt      DateTime?
  acceptedAt    DateTime?
  declinedAt    DateTime?
  declineReason String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id])
  dealId      String?
  deal        Deal?    @relation(fields: [dealId], references: [id])
  createdById String?
  createdBy   User?    @relation("QuoteCreator", fields: [createdById], references: [id])

  items QuoteItem[]

  @@map("quotes")
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
  CONVERTED
}

model QuoteItem {
  id          String @id @default(cuid())
  quoteId     String
  quote       Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  order       Int
  description String
  type        String @default("SERVICE")
  quantity    Int    @default(1)
  unitPrice   Float
  discount    Float  @default(0)
  totalPrice  Float
  notes       String?

  @@map("quote_items")
}

// ─────────────────────────────────────────────
// IMPORTS
// ─────────────────────────────────────────────

model ImportLog {
  id          String       @id @default(cuid())
  fileName    String
  fileType    String
  entityType  String       @default("CONTACT")
  totalRows   Int
  successRows Int          @default(0)
  errorRows   Int          @default(0)
  duplicates  Int          @default(0)
  status      ImportStatus @default(PROCESSING)
  errors      Json?
  createdById String?
  createdBy   User?        @relation("ImportLogCreator", fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())
  completedAt DateTime?

  @@map("import_logs")
}

enum ImportStatus {
  PROCESSING
  COMPLETED
  FAILED
}

// ─────────────────────────────────────────────
// COMPANY SETTINGS
// ─────────────────────────────────────────────

model CompanySettings {
  id             String   @id @default("singleton")
  companyName    String   @default("Travel CRM")
  logoUrl        String?
  address        String?
  city           String?
  state          String?
  pincode        String?
  country        String   @default("India")
  phone          String?
  email          String?
  website        String?
  gstin          String?
  pan            String?
  invoicePrefix  String   @default("INV")
  invoiceFooter  String?
  currency           String   @default("INR")
  canvaTemplateId    String?
  updatedAt          DateTime @updatedAt

  @@map("company_settings")
}

// ─────────────────────────────────────────────
// SCHEDULED JOBS
// ─────────────────────────────────────────────

model ScheduledJobLog {
  id        String   @id @default(cuid())
  jobName   String
  ranAt     DateTime @default(now())
  processed Int      @default(0)
  errors    Int      @default(0)
  details   Json?

  @@map("scheduled_job_logs")
}

// ─────────────────────────────────────────────
// OMNICHANNEL INBOX
// ─────────────────────────────────────────────

model Conversation {
  id            String              @id @default(cuid())
  channel       MessageChannel
  contactId     String
  contact       Contact             @relation(fields: [contactId], references: [id])
  externalId    String?
  status        ConversationStatus  @default(OPEN)
  lastMessageAt DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  messages      ConversationMessage[]
  assignedToId  String?
  assignedTo    User?               @relation("ConversationAssignee", fields: [assignedToId], references: [id])

  @@map("conversations")
}

model ConversationMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction      MessageDirection
  body           String           @db.Text
  status         MessageStatus    @default(SENT)
  twilioSid      String?
  sentAt         DateTime         @default(now())
  sentById       String?
  sentBy         User?            @relation("MessageSender", fields: [sentById], references: [id])

  @@map("conversation_messages")
}

enum ConversationStatus {
  OPEN
  RESOLVED
  PENDING
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}
